[project]
org='geisa'
name='tests'

[build]
command='shellcheck -xo all launch_conformance_tests.sh src/launch_conformance_tests_ssh.sh src/cukinia-tests/tests.d/*.sh \
&& pylint src/launch_conformance_tests_serial.py && black --check --diff src/launch_conformance_tests_serial.py'
user_extra_groups='dialout tty'

docker_run_args='--network=host'
